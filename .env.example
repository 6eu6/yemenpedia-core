# ===========================================
# YEMENPEDIA ENVIRONMENT VARIABLES (V5.1)
# ===========================================
# Copy this file to .env and fill in your values

# DATABASE (PostgreSQL - Supabase Pooler)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# STORAGE (Cloudflare R2)
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET_NAME="yemenpedia-media"
R2_PUBLIC_URL="https://your-bucket.r2.dev"
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"

# VIDEO (Bunny Stream)
BUNNY_API_KEY="your-bunny-api-key"
BUNNY_LIBRARY_ID="your-library-id"
BUNNY_CDN_HOSTNAME="your-cdn-hostname.b-cdn.net"

# EMAIL (Resend)
RESEND_API_KEY="your-resend-api-key"

# OAUTH (Google)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# AUTHENTICATION
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# OPERATIONS
CRON_SECRET="your-cron-secret-here"
ADMIN_BACKUP_KEY="your-backup-key-here"
SETUP_SECRET="your-setup-secret-here"

# IMAGE PROCESSING
IMAGE_MAX_WIDTH="1200"
IMAGE_QUALITY="85"
MAX_IMAGE_SIZE="10485760"
MAX_VIDEO_SIZE="524288000"
MAX_AUDIO_SIZE="52428800"
MAX_PDF_SIZE="20971520"
AVATAR_SIZE="400"
THUMBNAIL_SIZE="300"

# APP
NODE_ENV="development"
