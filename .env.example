# ===========================================
# YEMENPEDIA ENVIRONMENT VARIABLES
# ===========================================
# SECURITY: Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control!

# ===========================================
# DATABASE (PostgreSQL - Supabase Pooler)
# ===========================================
# IMPORTANT: Use Pooler URL for IPv4 compatibility
DATABASE_URL="postgresql://USER:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres?pgbouncer=true"
SUPABASE_POOLER_URL="postgresql://USER:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# ===========================================
# STORAGE (Cloudflare R2)
# ===========================================
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="yemenpedia-media"
R2_PUBLIC_URL="https://your-bucket-url.r2.dev"
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"

# ===========================================
# VIDEO (Bunny Stream)
# ===========================================
BUNNY_API_KEY="your-bunny-api-key"
BUNNY_LIBRARY_ID="your-library-id"
BUNNY_CDN_HOSTNAME="your-cdn-hostname.b-cdn.net"

# ===========================================
# EMAIL (Resend)
# ===========================================
RESEND_API_KEY="re_your-resend-api-key"

# ===========================================
# OAUTH (Google)
# ===========================================
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ===========================================
# AUTHENTICATION
# ===========================================
# SECURITY: Generate strong secrets with: openssl rand -base64 32
NEXTAUTH_SECRET="GENERATE_WITH_openssl_rand_base64_32"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# OPERATIONS
# ===========================================
# SECURITY: Generate strong secrets with: openssl rand -hex 32
CRON_SECRET="GENERATE_WITH_openssl_rand_hex_32"
ADMIN_BACKUP_KEY="GENERATE_WITH_openssl_rand_hex_32"

# ===========================================
# IMAGE PROCESSING DEFAULTS
# ===========================================
IMAGE_MAX_WIDTH="1200"
IMAGE_QUALITY="85"
MAX_IMAGE_SIZE="10485760"
MAX_VIDEO_SIZE="524288000"
MAX_AUDIO_SIZE="52428800"
MAX_PDF_SIZE="20971520"
AVATAR_SIZE="400"
THUMBNAIL_SIZE="300"

# ===========================================
# APP
# ===========================================
NODE_ENV="development"

# ===========================================
# SECURITY HEADERS
# ===========================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS="http://localhost:3000,https://yemenpedia.org"
